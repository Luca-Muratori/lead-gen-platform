{
  "name": "lead-gen-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "postinstall": "npm run db:generate", 
    "db:generate": "prisma generate --schema=./packages/shared/prisma/schema.prisma",
    "build": "npm run db:generate && npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm test --workspaces --if-present",
    "test:root": "jest",
    "db:push": "prisma db push --schema=./packages/shared/prisma/schema.prisma"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/supertest": "^7.2.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "prisma": "^7.5.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2"
  },
  "dependencies": {
    "@prisma/client": "^7.5.0",
    "zod": "^4.3.6"
  }
}
