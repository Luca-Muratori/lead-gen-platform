generator client {
  provider = "prisma-client-js"
  // This tells Prisma to generate the JS/TS client
}

datasource db {
  provider = "mongodb"
}

model Lead {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String
  name      String?
  source    String   
  status    String   @default("NEW") 
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}